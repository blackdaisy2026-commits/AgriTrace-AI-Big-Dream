# AgriTraceTN Environment Variables
# Copy to .env.local and fill in your values

# Polygon Mumbai RPC (get from alchemy.com - free)
NEXT_PUBLIC_ALCHEMY_MUMBAI_URL=https://polygon-mumbai.g.alchemy.com/v2/YOUR_ALCHEMY_KEY_HERE

# Smart Contract (deploy SupplyChain.sol to Polygon Mumbai via Remix IDE)
NEXT_PUBLIC_CONTRACT_ADDRESS=0xYourDeployedContractAddress

# Cloudinary (optional - for farm photo uploads)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=agritrace_unsigned

# App URL (for QR code generation)
NEXT_PUBLIC_APP_URL=http://localhost:3000
