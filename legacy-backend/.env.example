# ─── Server ─────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ─────────────────────────────────────────────
# Use MongoDB Atlas (free tier) or local MongoDB
MONGO_URI=mongodb://localhost:27017/agritrace
# For Atlas: MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/agritrace

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET=agritrace_super_secret_key_change_in_production
JWT_EXPIRES_IN=7d

# ─── Blockchain ──────────────────────────────────────────
# Mode: "simulate" (no wallet needed) | "testnet" (Polygon Amoy)
BLOCKCHAIN_MODE=simulate

# For testnet mode:
# ALCHEMY_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_KEY
# DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
# CONTRACT_ADDRESS=0xYOUR_DEPLOYED_CONTRACT

# ─── Frontend ────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
